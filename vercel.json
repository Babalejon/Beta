{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.ts",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/requirements",
      "dest": "/api/requirements.ts",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/api/checklist",
      "dest": "/api/checklist.ts",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
